# 应用配置
DEBUG=true
HOST=127.0.0.1
PORT=8000

# AI服务配置
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# TTS服务配置
TTS_API_BASE=http://127.0.0.1:5000

# Whisper配置
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=zh

# 帧匹配配置
FRAME_MATCH_THRESHOLD=0.85
PHASH_THRESHOLD=10
SCENE_THRESHOLD=30.0

# 声纹识别配置
VOICEPRINT_THRESHOLD=0.75

# 剪映草稿路径
JIANYING_DRAFTS_DIR=D:\my_video_project\jianyingcaogao\JianyingPro Drafts
